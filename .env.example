# OpenAQ API key — obtain a free key at https://explore.openaq.org/register
OPENAQ_API_KEY=

# Google Places API key (optional — used only as factory data fallback)
GOOGLE_PLACES_API_KEY=

# data.gov.in API key (optional — increases rate limit for CPCB source)
# Register at https://data.gov.in/user/register
DATAGOV_API_KEY=

# Set to 'true' ONLY in local dev/CI to permit synthetic data when all real
# sources fail. NEVER set this to true in production.
ALLOW_SYNTHETIC_DATA=false

DEFAULT_COUNTRY=India
LOG_LEVEL=INFO

# Backend API runtime settings
API_HOST=0.0.0.0
API_PORT=8000
CACHE_TTL_SECONDS=300

# Dataset path overrides (optional)
FACTORIES_CSV=data/raw/factories/factories.csv
RAW_POLLUTION_CSV=data/raw/pollution/pollution_readings.csv
PROCESSED_POLLUTION_FILE=data/processed/ml_dataset.parquet
RECOMMENDATIONS_CSV=data/output/recommendations.csv
